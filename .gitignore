# -------------------------
# IntelliJ IDEA
# -------------------------
.idea/
*.iml
# Optional: ignore workspace and run configs that are user-specific
.idea/workspace.xml
.idea/tasks.xml
.idea/dictionaries/
.idea/gradle.xml
.idea/usage.statistics.xml
# Keep code style and shared settings if your team commits them:
# .idea/codeStyles/

# -------------------------
# Gradle
# -------------------------
/.gradle/
/build/
/out/
# Gradle wrapper files should usually be committed (gradle/wrapper/gradle-wrapper.jar and properties)

# -------------------------
# Java
# -------------------------
*.class
*.jar
*.war
*.ear

# -------------------------
# Spring Boot / config / secrets
# -------------------------
# Ignore local config files that may contain secrets
/src/main/resources/application-*.yml
# Keep an example config for repo
!src/main/resources/application.yml.example

# -------------------------
# Logs and temp
# -------------------------
*.log
logs/
tmp/
temp/
*.tmp

# -------------------------
# OS files
# -------------------------
.DS_Store
Thumbs.db

# -------------------------
# IDEs and editors (other)
# -------------------------
.vscode/
*.swp
*~.nib
*.sublime-workspace
*.sublime-project

# -------------------------
# Test / coverage / reports
# -------------------------
/coverage/
/reports/
/test-results/

# -------------------------
# Build tool / CI
# -------------------------
# local gradle properties that may contain credentials
gradle.properties
# If you commit gradle.properties for CI, remove the above line

# -------------------------
# Misc
# -------------------------
.env
.env.local
.env.*.local
.secrets/